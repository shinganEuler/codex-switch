{
  "name": "codex-identity-router",
  "author": "shinganEuler",
  "repository": {
    "type": "git",
    "url": "https://github.com/shinganEuler/codex-switch"
  },
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "1.3.6",
  "license": "MIT",
  "publisher": "shinganeuler",
  "files": [
    "out/**",
    "resources/**",
    "l10n/**",
    "package.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "package.nls*.json"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "vscode:publish": "vsce publish",
    "openvsx:publish": "npx ovsx publish",
    "compile": "tsc -p ./",
    "lint:ts": "eslint \"src/**/*.ts\" --max-warnings=0",
    "lint:md": "markdownlint-cli2",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npm run lint:ts && npm run lint:md && npm run format:check",
    "vscode:package": "vsce package",
    "watch": "tsc -watch -p ./"
  },
  "engines": {
    "vscode": "^1.105.1",
    "node": ">=24 <25"
  },
  "categories": [
    "Other"
  ],
  "icon": "resources/codex-identity-router.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "commands": [
      {
        "command": "codex-identity-router.login",
        "title": "%command.login.title%"
      },
      {
        "command": "codex-identity-router.profile.manage",
        "title": "%command.profile.manage.title%"
      },
      {
        "command": "codex-identity-router.profile.login",
        "title": "%command.profile.login.title%"
      },
      {
        "command": "codex-identity-router.profile.switch",
        "title": "%command.profile.switch.title%"
      },
      {
        "command": "codex-identity-router.profile.toggleLast",
        "title": "%command.profile.toggleLast.title%"
      },
      {
        "command": "codex-identity-router.profile.addFromCodexAuthFile",
        "title": "%command.profile.addFromCodexAuthFile.title%"
      },
      {
        "command": "codex-identity-router.profile.addFromFile",
        "title": "%command.profile.addFromFile.title%"
      },
      {
        "command": "codex-identity-router.profile.exportSettings",
        "title": "%command.profile.exportSettings.title%"
      },
      {
        "command": "codex-identity-router.profile.importSettings",
        "title": "%command.profile.importSettings.title%"
      },
      {
        "command": "codex-identity-router.profile.rename",
        "title": "%command.profile.rename.title%"
      },
      {
        "command": "codex-identity-router.profile.delete",
        "title": "%command.profile.delete.title%"
      }
    ],
    "menus": {
      "statusBar/item/context": [
        {
          "command": "codex-identity-router.profile.manage",
          "when": "statusBarItemId == codex-identity-router.profile",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "codexIdentityRouter.debugLogging": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.debugLogging.description%"
        },
        "codexIdentityRouter.activeProfileScope": {
          "type": "string",
          "enum": [
            "global",
            "workspace"
          ],
          "default": "global",
          "description": "%configuration.activeProfileScope.description%"
        },
        "codexIdentityRouter.storageMode": {
          "type": "string",
          "enum": [
            "auto",
            "secretStorage",
            "remoteFiles",
            "customRemoteFiles"
          ],
          "default": "auto",
          "description": "%configuration.storageMode.description%",
          "enumDescriptions": [
            "%configuration.storageMode.auto%",
            "%configuration.storageMode.secretStorage%",
            "%configuration.storageMode.remoteFiles%",
            "%configuration.storageMode.customRemoteFiles%"
          ]
        },
        "codexIdentityRouter.remoteFilesRoot": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "%configuration.remoteFilesRoot.description%",
          "when": "config.codexIdentityRouter.storageMode == customRemoteFiles"
        },
        "codexIdentityRouter.reloadWindowAfterProfileSwitch": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.reloadWindowAfterProfileSwitch.description%"
        },
        "codexIdentityRouter.statusBarClickBehavior": {
          "type": "string",
          "enum": [
            "cycle",
            "toggleLast"
          ],
          "default": "cycle",
          "description": "%configuration.statusBarClickBehavior.description%",
          "enumDescriptions": [
            "%configuration.statusBarClickBehavior.cycle%",
            "%configuration.statusBarClickBehavior.toggleLast%"
          ]
        }
      }
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "24.x",
    "@types/vscode": "^1.105.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "markdownlint-cli2": "^0.21.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "@vscode/vsce": "^3.7.1"
  }
}
